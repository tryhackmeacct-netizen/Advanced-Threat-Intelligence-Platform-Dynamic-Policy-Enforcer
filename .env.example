################################################################################
# Advanced Threat Intelligence Platform - Environment Configuration
# 
# SECURITY WARNING: Never commit actual credentials to version control.
# This file is a TEMPLATE. Copy it to .env and fill in real values locally.
# The .env file is git-ignored and will not be committed.
#
# Setup: cp .env.example .env
#        chmod 600 .env  (Linux/Mac)
#        Then edit .env with actual credentials
################################################################################

# ============================================================================
# ELASTICSEARCH CONFIGURATION (Required for SIEM forwarding)
# ============================================================================
# Elasticsearch URL (with TLS)
ELASTICSEARCH_URL=https://localhost:9200

# Elasticsearch authentication user
ELASTICSEARCH_USER=elastic

# Elasticsearch authentication password (REQUIRED - no default)
# Set this to your actual Elasticsearch password
ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# Path to Elasticsearch CA certificate for TLS validation
ELASTICSEARCH_CA_CERT_PATH=/etc/elasticsearch/certs/http_ca.crt

# Enable TLS certificate verification (recommended: 1 for production)
ELASTICSEARCH_VERIFY_CERTS=1

# Allow insecure fallback only if TLS validation fails (not recommended for production)
ELASTICSEARCH_ALLOW_INSECURE_FALLBACK=0

# ============================================================================
# MONGODB CONFIGURATION (Required for IOC storage)
# ============================================================================
MONGO_URI=mongodb://localhost:27017/
DB_NAME=threat_intelligence
COLLECTION_NAME=ioc_data

# Optional: MongoDB authentication (if auth is enabled)
# MONGO_USER=admin
# MONGO_PASSWORD=your_mongo_password
# MONGO_AUTH_SOURCE=admin

# ============================================================================
# OSINT FEED API KEYS (Optional - demo mode works without these)
# ============================================================================
# Get free keys from:
# - AlienVault OTX: https://otx.alienvault.com/api
# - AbuseIPDB: https://www.abuseipdb.com/api
# - VirusTotal: https://www.virustotal.com/gui/home/upload (requires credit card)

VIRUSTOTAL_API_KEY=your_virustotal_api_key
ALIENVAULT_API_KEY=your_alienvault_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Default indicators to process (comma-separated IPs/domains)
DEFAULT_FEED_INDICATORS=8.8.8.8,185.220.101.1,1.2.3.4

# Enable demo mode fallback (allows testing without real API keys)
ENABLE_DEMO_FALLBACK=1

# Risk threshold for firewall blocking (0-100, default: 80)
RISK_THRESHOLD=80

# Enable firewall policy enforcement
FIREWALL_ENABLED=1

# Enable SIEM logging to Elasticsearch
SIEM_ENABLED=1

# Elasticsearch index name for threat intelligence
ES_INDEX_NAME=threat_intelligence

# MongoDB collection for blocked IPs
BLOCKED_IPS_COLLECTION=blocked_ips

################################################################################
# NOTES
# ============================================================================
# 1. All credentials can be set as environment variables instead of .env:
#    export ELASTICSEARCH_PASSWORD="your_password"
#    export VIRUSTOTAL_API_KEY="your_key"
#
# 2. For production, use a secrets management tool:
#    - Kubernetes Secrets
#    - Docker Secrets
#    - HashiCorp Vault
#    - AWS Secrets Manager
#
# 3. File permissions (Linux/Mac):
#    chmod 600 .env  # Only owner can read/write
#
# 4. Verify .env is git-ignored:
#    grep "^\.env" .gitignore
################################################################################

